<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@mipmap/ic_launcher"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/welcome_title"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/welcome_subtitle"
            android:textSize="16sp"
            android:textAlignment="center"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_quick_add"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_add_date_widget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_add_date"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_add_weekly_widget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_add_weekly"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_add_daily_widget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_add_daily"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_instructions"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/instruction_text"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btn_report_bug"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Report a Bug / Send Feedback"
            android:textColor="?attr/colorPrimary"
            app:strokeColor="?attr/colorPrimary"
            android:layout_marginBottom="16dp"
            android:textAllCaps="false"/>

        <TextView
            android:id="@+id/tv_privacy_policy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_privacy_policy"
            android:textColor="?attr/colorPrimary"
            android:padding="8dp"/>

    </LinearLayout>
</ScrollView>
