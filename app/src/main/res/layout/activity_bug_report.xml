<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="20dp"
    tools:context=".BugReportActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bug Report &amp; Feedback"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Help us make Cal Date Widget better by reporting bugs or sharing suggestions. Please describe the issue below. If this is a visual/layout bug, please attach a screenshot in your email client!"
            android:textColor="#B0B0B0"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Description Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_description"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="What went wrong?"
            android:textColorHint="#80FFFFFF"
            app:boxStrokeColor="#80FFFFFF"
            app:boxStrokeWidth="1dp"
            app:boxCornerRadiusTopStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusBottomEnd="8dp"
            app:hintTextColor="?attr/colorPrimary"
            android:layout_marginBottom="20dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="4"
                android:gravity="top"
                android:inputType="textMultiLine|textCapSentences"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Toggle Switches -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="#1E1E1E"
            app:strokeWidth="0dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_system_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Include System &amp; Settings Info"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:checked="true"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Includes device manufacturer/model, Android OS version, number of active widgets, and widget display settings (no personal identifiers)."
                    android:textColor="#B0B0B0"
                    android:textSize="12sp"
                    android:layout_marginBottom="16dp"
                    android:layout_marginStart="4dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#33FFFFFF"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_app_logs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Include Recent App Logs (Logcat)"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:checked="true"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Includes the last ~200 lines of console logs printed by the widget provider. Critical for fixing layout, crash, or refresh problems."
                    android:textColor="#B0B0B0"
                    android:textSize="12sp"
                    android:layout_marginStart="4dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Preview Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="#1E1E1E"
            app:strokeWidth="1dp"
            app:strokeColor="#33FFFFFF"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Header trigger -->
                <LinearLayout
                    android:id="@+id/layout_preview_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Preview Diagnostics &amp; Logs"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="15sp" />

                    <ImageView
                        android:id="@+id/img_preview_arrow"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/arrow_down_float"
                        app:tint="#FFFFFF" />
                </LinearLayout>

                <!-- Expandable content container -->
                <LinearLayout
                    android:id="@+id/layout_preview_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp"
                    android:visibility="gone">

                    <ProgressBar
                        android:id="@+id/progress_preview"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:layout_margin="16dp"
                        android:visibility="gone"/>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        
                        <TextView
                            android:id="@+id/tv_preview"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#8BC34A"
                            android:textSize="12sp"
                            android:fontFamily="monospace"
                            android:textIsSelectable="true"
                            tools:text="Diagnostics dump..." />
                    </HorizontalScrollView>

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Submit Buttons -->
        <Button
            android:id="@+id/btn_submit_report"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Send Bug Report via Email"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_copy_report"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Copy Diagnostics to Clipboard"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:textSize="15sp"
            app:strokeColor="#80FFFFFF"
            app:cornerRadius="8dp"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
