# Release Signing Configuration Example
# Copy this file to 'keystore.properties' and fill in your actual credentials.
# Make sure 'keystore.properties' and your keystore file (*.jks) are NEVER committed to Git.

# Path to your release keystore file. 
# Can be absolute path or relative to the app/ directory (e.g., ../my-release-key.jks)
storeFile=../my-release-key.jks

# The passwords and alias you defined when creating the keystore
storePassword=your_keystore_password
keyAlias=your_key_alias
keyPassword=your_key_password
