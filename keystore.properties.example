# Release Signing Configuration Example
# You can add these to 'local.properties' (recommended for this project) 
# or your global '~/.gradle/gradle.properties'.
#
# Make sure your keystore file (*.jks/*.keystore) is NEVER committed to Git.

# Path to your release keystore file.
RELEASE_STORE_FILE=../my-release-key.jks

# The passwords and alias you defined when creating the keystore
RELEASE_STORE_PASSWORD=your_keystore_password
RELEASE_KEY_ALIAS=your_key_alias
RELEASE_KEY_PASSWORD=your_key_password
